# BreakNWipe Blockchain Configuration
# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file — it contains private keys.

# Blockchain Network Configuration (Sepolia testnet example)
BREAKNWIPE_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
BREAKNWIPE_CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS
BREAKNWIPE_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
BREAKNWIPE_CHAIN_ID=11155111

# Datawipe Verification Webapp Integration
DATAWIPE_BASE_URL=https://datawipe.vercel.app
DATAWIPE_VERIFICATION_ENDPOINT=/api/verify

# BreakNWipe Blockchain Settings
BREAKNWIPE_AUTO_BLOCKCHAIN_STORE=true
BREAKNWIPE_QR_INCLUDE_BLOCKCHAIN=true
BREAKNWIPE_STORAGE_METHOD=onchain
